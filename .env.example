# URL publique du site (sans slash final). Utilisée pour canonical, Open Graph, JSON-LD et sitemap.
# À définir sur Vercel (Production + Preview) : ex. https://www.brunisanitaire.fr
# Valeur factice pour le développement local :
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Injectée automatiquement par Vercel (preview / prod). Laisser vide en local ; pas besoin de la créer sur le dashboard.
# Exemple factice pour tester localement le comportement « preview » :
VERCEL_URL=
